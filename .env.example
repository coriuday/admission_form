# ── Google Sheets Integration ───────────────────────────────────────────────
# GOOGLE_SHEET_ID: The ID from your Google Sheet URL.
# Example URL: https://docs.google.com/spreadsheets/d/<THIS_PART_IS_THE_ID>/edit
GOOGLE_SHEET_ID="YOUR_GOOGLE_SHEET_ID"

# GOOGLE_CLIENT_EMAIL: The service account email from your Google Cloud JSON key file.
# Example: my-bot@my-project.iam.gserviceaccount.com
GOOGLE_CLIENT_EMAIL="YOUR_SERVICE_ACCOUNT_EMAIL"

# GOOGLE_PRIVATE_KEY: The private key from your Google Cloud JSON key file.
# Keep the quotes and preserve the \n characters exactly as they appear in the JSON.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
